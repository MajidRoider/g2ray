{
  "name": "g2ray",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postAttachCommand": {
    "expose": "gh codespace ports visibility 8698:public -c $CODESPACE_NAME",
    "start": "sudo /usr/local/bin/xray run -c /etc/xray/g2ray.json"
  },
  "portsAttributes": {
    "8698": {
      "label": "g2ray",
      "protocol": "http",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [8698],
  "hostRequirements": {
    "cpus": 2
  }
}
